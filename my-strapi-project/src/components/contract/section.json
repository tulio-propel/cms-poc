{
  "collectionName": "components_contract_sections",
  "info": {
    "displayName": "Section",
    "description": "Purpose: represent each contract clause/section."
  },
  "options": {},
  "attributes": {
    "order": {
      "type": "integer",
      "required": true
    },
    "heading": {
      "type": "string",
      "required": true
    },
    "body": {
      "type": "blocks",
      "required": true
    },
    "body_html": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "body_markdown": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultMarkdown"
      }
    }
  },
  "config": {}
}
